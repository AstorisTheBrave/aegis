{
  "name": "@aegis/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --format=esm --target=node24 --packages=bundle --external:fastify --external:pg --outfile=dist/server.js",
    "dev": "node dist/server.js",
    "lint": "prettier --check . --ignore-path ../../.prettierignore",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aegis/action-engine": "workspace:*",
    "@aegis/api-contract": "workspace:*",
    "@aegis/discovery": "workspace:*",
    "@aegis/evidence-export": "workspace:*",
    "@aegis/extension-registry": "workspace:*",
    "@aegis/findings": "workspace:*",
    "@aegis/ingestion": "workspace:*",
    "@aegis/reviews": "workspace:*",
    "@aegis/review-policies": "workspace:*",
    "@aegis/saas-catalog": "workspace:*",
    "@aegis/workflow-engine": "workspace:*",
    "@aegis/workflow-templates": "workspace:*",
    "@open-saas-governance/postgres-store": "workspace:*",
    "@open-saas-governance/access-graph": "workspace:*",
    "@open-saas-governance/audit-ledger": "workspace:*",
    "fastify": "5.10.0",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "esbuild": "0.28.1",
    "@types/node": "24.1.0",
    "@types/pg": "8.20.0",
    "vitest": "4.1.10"
  }
}
